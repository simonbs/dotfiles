{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(sudo rm -rf*)",
      "Bash(mkfs*)",
      "Bash(dd if=*of=/dev/*)",
      "Bash(shutdown*)",
      "Bash(reboot*)"
    ],
    "ask": []
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/opt/homebrew/Cellar/node/25.9.0_2/bin/node' '/opt/homebrew/Cellar/brrr/0.1.5/libexec/dist/src/cli.js' agent dispatch --agent claude --event finished --webhook '$BRRR_WEBHOOK_URL' --idle-seconds 20 # brrr:claude:stop:v1",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "'/opt/homebrew/Cellar/node/25.9.0_2/bin/node' '/opt/homebrew/Cellar/brrr/0.1.5/libexec/dist/src/cli.js' agent dispatch --agent claude --event needs-approval --webhook '$BRRR_WEBHOOK_URL' --idle-seconds 20 # brrr:claude:notification:permission_prompt:v1",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "'/opt/homebrew/Cellar/node/25.9.0_2/bin/node' '/opt/homebrew/Cellar/brrr/0.1.5/libexec/dist/src/cli.js' agent dispatch --agent claude --event needs-approval --webhook '$BRRR_WEBHOOK_URL' --idle-seconds 20 # brrr:claude:pretooluse:askuserquestion:v1",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "teammateMode": "tmux"
}
